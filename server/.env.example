# ─── PitchSync Server ────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/pitchsync

# JWT signing secret — use a long, random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_minimum_32_chars

# Resend API key for transactional email (password reset)
# https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Origin allowed by CORS — must match the frontend dev server
FRONTEND_URL=http://localhost:5173

# Port the Express server listens on
PORT=3001
